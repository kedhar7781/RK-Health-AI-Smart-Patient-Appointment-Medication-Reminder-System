# RK Health - Environment Configurations Template

# Flask Core Session Secret
SECRET_KEY=rk_health_secret_key_129837198273

# Optional: Override local SQLite DB Path (Defaults to backend/rk_health.db)
# DATABASE_PATH=C:/path/to/custom/rk_health.db

# Google Apps Script Web App Deployment URL (For Sheets Database & Calendar Events)
GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/xxxxxx-xxxxxx/exec

# Twilio SMS Configurations (To trigger text alerts to patient phones)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15550005555

# OpenAI/Grok/Llama Compatible API Configuration (For summary reports)
AI_API_KEY=sk-xxxxxx-xxxxxx-xxxxxx
# Custom API Endpoint Base URL (e.g. OpenAI, Grok, or local Llama server)
AI_API_BASE=https://api.openai.com/v1
AI_MODEL=gpt-3.5-turbo
